{
  "name": "casework-automation",
  "version": "1.0.0",
  "type": "module",
  "description": "WebdriverIO test automation for theCaseWork – full coverage capstone project",
  "scripts": {
    "test":              "npx wdio run wdio.conf.js",
    "test:logout":       "npx wdio run wdio.conf.js --spec ./test/specs/logout.spec.js",
    "test:account":      "npx wdio run wdio.conf.js --spec ./test/specs/userAccountMenu.spec.js",
    "test:datatypes":    "npx wdio run wdio.conf.js --spec ./test/specs/caseDataTypes.spec.js",
    "test:clients":      "npx wdio run wdio.conf.js --spec ./test/specs/clients.spec.js",
    "test:legal":        "npx wdio run wdio.conf.js --spec ./test/specs/legalDocs.spec.js"
  },
  "devDependencies": {
    "@wdio/cli":            "^9.0.0",
    "@wdio/local-runner":   "^9.0.0",
    "@wdio/mocha-framework":"^9.0.0",
    "@wdio/spec-reporter":  "^9.0.0",
    "dotenv":               "^16.0.0"
  }
}